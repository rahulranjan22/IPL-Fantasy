# ── Vercel Environment Variables ──────────────────────────────
# Add these in: Vercel Dashboard → Project → Settings → Environment Variables

# Your Render backend URL (after deploying to Render)
NEXT_PUBLIC_API_URL=https://ipl-fantasy-api.onrender.com

# Supabase project (from: supabase.com → Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON=your-anon-public-key
